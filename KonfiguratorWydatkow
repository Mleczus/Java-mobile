import android.view.LayoutInflater;
import android.view.View;
import android.view.ViewGroup;
import android.widget.Button;
import android.widget.TextView;

import androidx.annotation.NonNull;
import androidx.recyclerview.widget.RecyclerView;

import java.util.ArrayList;
import java.util.Locale;

public class WydatekAdapter extends RecyclerView.Adapter<WydatekAdapter.WydatekViewHolder> {

    public interface OnWydatekActionListener {
        void onDeleteClicked(int position);
        void onItemClicked(Wydatek wydatek);
    }

    private final ArrayList<Wydatek> lista;
    private final OnWydatekActionListener listener;

    public WydatekAdapter(ArrayList<Wydatek> lista, OnWydatekActionListener listener) {
        this.lista = lista;
        this.listener = listener;
    }

    @NonNull
    @Override
    public WydatekViewHolder onCreateViewHolder(@NonNull ViewGroup parent, int viewType) {
        View view = LayoutInflater.from(parent.getContext())
                .inflate(R.layout.item_wydatek, parent, false);
        return new WydatekViewHolder(view);
    }

    @Override
    public void onBindViewHolder(@NonNull WydatekViewHolder holder, int position) {
        Wydatek w = lista.get(position);

        holder.tekstNazwa.setText(w.getNazwa());
        holder.tekstKategoria.setText(w.getKategoria());
        holder.tekstKwota.setText(String.format(Locale.getDefault(), "%.2f zł", w.getKwota()));

        holder.przyciskUsun.setOnClickListener(v ->
                listener.onDeleteClicked(holder.getAdapterPosition()));

        holder.itemView.setOnClickListener(v ->
                listener.onItemClicked(w));
    }

    @Override
    public int getItemCount() {
        return lista.size();
    }

    public void dodajWydatek(Wydatek w) {
        lista.add(w);
        notifyItemInserted(lista.size() - 1);
    }

    public void usunWydatek(int position) {
        if (position < 0 || position >= lista.size()) return;
        lista.remove(position);
        notifyItemRemoved(position);
    }

    static class WydatekViewHolder extends RecyclerView.ViewHolder {
        TextView tekstNazwa, tekstKategoria, tekstKwota;
        Button przyciskUsun;

        public WydatekViewHolder(@NonNull View itemView) {
            super(itemView);
            tekstNazwa = itemView.findViewById(R.id.tekstNazwa);
            tekstKategoria = itemView.findViewById(R.id.tekstKategoria);
            tekstKwota = itemView.findViewById(R.id.tekstKwota);
            przyciskUsun = itemView.findViewById(R.id.przyciskUsun);
        }
    }
}



// MainActivity.java 

import android.os.Bundle;
import android.view.View;
import android.widget.*;

import androidx.appcompat.app.AppCompatActivity;
import androidx.recyclerview.widget.LinearLayoutManager;
import androidx.recyclerview.widget.RecyclerView;

import java.util.ArrayList;
import java.util.Locale;

public class MainActivity extends AppCompatActivity implements View.OnClickListener, WydatekAdapter.OnWydatekActionListener {

    private final ArrayList<Wydatek> lista = new ArrayList<>();

    private EditText nazwa, kwota;
    private Spinner spinner;
    private TextView pustaLista;
    private TextView tekstLiczbaWydatkow;
    private TextView tekstSumaWydatkow;
    private TextView tekstNajdrozszy;

    private RecyclerView recycler;
    private WydatekAdapter adapter;

    private static final String KEY_LISTA = "lista_wydatkow";

    @Override
    protected void onCreate(Bundle savedInstanceState) {
        super.onCreate(savedInstanceState);
        setContentView(R.layout.activity_main);

        nazwa = findViewById(R.id.poleNazwaWydatku);
        kwota = findViewById(R.id.poleKwotaWydatku);
        spinner = findViewById(R.id.spinnerKategoria);
        pustaLista = findViewById(R.id.tekstPustaLista);

        tekstLiczbaWydatkow = findViewById(R.id.tekstLiczbaWydatkow);
        tekstSumaWydatkow = findViewById(R.id.tekstSumaWydatkow);
        tekstNajdrozszy = findViewById(R.id.tekstNajdrozszy);

        recycler = findViewById(R.id.listaWydatkow);
        Button btn = findViewById(R.id.przyciskZapisz);

        adapter = new WydatekAdapter(lista, this);
        recycler.setLayoutManager(new LinearLayoutManager(this));
        recycler.setAdapter(adapter);

        btn.setOnClickListener(this);

        if (savedInstanceState != null) {
            ArrayList<Wydatek> zapisane =
                    (ArrayList<Wydatek>) savedInstanceState.getSerializable(KEY_LISTA);

            if (zapisane != null) {
                lista.clear();
                lista.addAll(zapisane);
                adapter.notifyDataSetChanged();
            }
        }

        odswiezPodsumowanie();
    }

    @Override
    public void onClick(View v) {
        String n = nazwa.getText().toString().trim();
        String k = kwota.getText().toString().trim();
        String kat = spinner.getSelectedItem().toString();

        if (n.isEmpty() || k.isEmpty()) {
            Toast.makeText(this, "Uzupełnij pola", Toast.LENGTH_SHORT).show();
            return;
        }

        double kw;
        try {
            kw = Double.parseDouble(k);
        } catch (NumberFormatException e) {
            Toast.makeText(this, "Zła kwota", Toast.LENGTH_SHORT).show();
            return;
        }

        Wydatek w = new Wydatek(n, kw, kat);
        adapter.dodajWydatek(w);

        recycler.smoothScrollToPosition(adapter.getItemCount() - 1);

        wyczysc();
        odswiezPodsumowanie();

        Toast.makeText(this, "Dodano", Toast.LENGTH_SHORT).show();
    }

    @Override
    public void onDeleteClicked(int position) {
        adapter.usunWydatek(position);
        odswiezPodsumowanie();
    }

    @Override
    public void onItemClicked(Wydatek w) {
        Toast.makeText(this, w.getNazwa(), Toast.LENGTH_SHORT).show();
    }

    private void odswiezPodsumowanie() {
        double suma = 0;
        Wydatek najdrozszy = null;
        double maxKwota = 0;

        for (Wydatek w : lista) {
            suma += w.getKwota();

            if (najdrozszy == null || w.getKwota() > maxKwota) {
                najdrozszy = w;
                maxKwota = w.getKwota();
            }
        }

        tekstLiczbaWydatkow.setText("Liczba wydatków: " + lista.size());

        tekstSumaWydatkow.setText(
                "Łączna suma: " +
                        String.format(Locale.getDefault(), "%.2f zł", suma)
        );

        if (lista.isEmpty()) {
            tekstNajdrozszy.setVisibility(View.GONE);
        } else {
            tekstNajdrozszy.setVisibility(View.VISIBLE);
            tekstNajdrozszy.setText(
                    "Najdroższy: " + najdrozszy.getNazwa() +
                            " za " + String.format(Locale.getDefault(), "%.2f zł", najdrozszy.getKwota())
            );
        }

        pustaLista.setVisibility(lista.isEmpty() ? View.VISIBLE : View.GONE);
    }

    private void wyczysc() {
        nazwa.setText("");
        kwota.setText("");
        spinner.setSelection(0);
    }

    @Override
    protected void onSaveInstanceState(Bundle outState) {
        super.onSaveInstanceState(outState);
        outState.putSerializable(KEY_LISTA, lista);
    }
}
